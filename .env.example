# Public site identity
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=AstraBlog
NEXT_PUBLIC_SITE_WORDMARK=ASTRABLOG
NEXT_PUBLIC_SITE_OWNER=Astra
NEXT_PUBLIC_SITE_DESCRIPTION=Software, systems and long-form thinking.
NEXT_PUBLIC_SITE_DESCRIPTION_ZH=关于软件工程、人工智能与数字世界的持续记录。
NEXT_PUBLIC_SITE_LOCALE=en
NEXT_PUBLIC_SITE_LANGUAGE=en-us
NEXT_PUBLIC_POSTS_PER_PAGE=12

# Optional public contact links (omit to hide the Connect section)
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_X_URL=

# Neon PostgreSQL
DATABASE_URL=
DATABASE_URL_DIRECT=

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters

# Email (console mode works without a Resend key)
DEV_EMAIL_MODE=console
RESEND_API_KEY=
EMAIL_FROM=AstraBlog <noreply@example.com>

# Cloudflare R2 media storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=astrablog-media
R2_PUBLIC_BASE_URL=

# Scheduled publishing endpoint
CRON_SECRET=

# Optional reusable seed identity
SEED_OWNER_EMAIL=dev@example.com
SEED_OWNER_NAME=Astra Developer
SEED_OWNER_USERNAME=astra_dev
